generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// User & Authentication Models
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  password      String?
  image         String?
  role          String    @default("VIEWER") // VIEWER, ADMIN, EDITOR
  companyId     String?
  
  company       Company?  @relation(fields: [companyId], references: [id])
  accounts      Account[]
  sessions      Session[]
  tasksAssigned Task[]    @relation("TaskAssignee")
  tasksCreated  Task[]    @relation("TaskCreator")
  auditLogs     AuditLog[]
  notifications Notification[]

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Core Domain Models

model Company {
  id                String   @id @default(cuid())
  name              String
  gst               String?
  pan               String?
  cin               String?
  msmeDetails       String?
  isoCertifications String?
  annualTurnover    String?
  experience        String?
  employees         Int?
  industries        String?
  products          String?
  services          String?
  officeLocations   String?
  contacts          String?
  subscriptionPlan  String   @default("FREE")
  
  users             User[]
  documents         CompanyDocument[]
  tenders           CompanyTender[]
  projects          Project[]
  proposals         Proposal[]
  eligibilityReports EligibilityReport[]
  settings          Setting?
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Tender {
  id                String   @id @default(cuid())
  title             String
  department        String
  state             String?
  tenderValue       Float?
  closingDate       DateTime?
  referenceNumber   String?
  description       String?
  
  // AI Generated fields
  executiveSummary  String?
  eligibilityReqs   String?
  requiredDocs      String?
  budgetSummary     String?
  techSummary       String?
  finSummary        String?
  importantClauses  String?
  riskAnalysis      String?
  timeline          String?
  deliverables      String?
  
  companies         CompanyTender[]
  documents         TenderDocument[]
  chatHistory       ChatHistory[]
  proposals         Proposal[]
  eligibilityReports EligibilityReport[]
  projects          Project[]
  
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

// Join table for Company - Tender relationship
model CompanyTender {
  id              String   @id @default(cuid())
  companyId       String
  tenderId        String
  status          String   @default("INTERESTED") // INTERESTED, EVALUATING, BIDDING, WON, LOST
  readinessScore  Float?
  
  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tender          Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([companyId, tenderId])
}

model CompanyDocument {
  id            String   @id @default(cuid())
  name          String
  type          String   // e.g. GST_CERTIFICATE, BALANCE_SHEET, PROFILE
  fileUrl       String
  expiryDate    DateTime?
  status        String   @default("ACTIVE")
  version       Int      @default(1)
  ocrData       String?
  companyId     String
  
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model TenderDocument {
  id            String   @id @default(cuid())
  name          String
  type          String   // e.g. NIT, BOQ, CORRIGENDUM
  fileUrl       String
  ocrData       String?
  tenderId      String
  
  tender        Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model ChatHistory {
  id            String   @id @default(cuid())
  tenderId      String
  userId        String?
  role          String   // "user" or "assistant"
  content       String
  
  tender        Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
}

model Project {
  id            String   @id @default(cuid())
  name          String
  description   String?
  status        String   @default("PLANNING")
  companyId     String
  tenderId      String?
  
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tender        Tender?  @relation(fields: [tenderId], references: [id])
  tasks         Task[]
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Task {
  id            String   @id @default(cuid())
  title         String
  description   String?
  status        String   @default("TODO")
  dueDate       DateTime?
  projectId     String
  assigneeId    String?
  creatorId     String
  
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee      User?    @relation("TaskAssignee", fields: [assigneeId], references: [id])
  creator       User     @relation("TaskCreator", fields: [creatorId], references: [id])
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Proposal {
  id               String   @id @default(cuid())
  companyId        String
  tenderId         String
  status           String   @default("DRAFT")
  coverLetter      String?
  execSummary      String?
  techProposal     String?
  methodology      String?
  riskPlan         String?
  compliance       String?
  fileUrl          String?
  
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tender           Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model EligibilityReport {
  id               String   @id @default(cuid())
  companyId        String
  tenderId         String
  overallMatch     Float
  missingReqs      String?
  recommendation   String?
  winProbability   Float?
  
  company          Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tender           Tender   @relation(fields: [tenderId], references: [id], onDelete: Cascade)
  
  createdAt        DateTime @default(now())
}

model Notification {
  id            String   @id @default(cuid())
  userId        String
  type          String   // ALERT, TASK, EXPIRY
  title         String
  message       String
  isRead        Boolean  @default(false)
  linkUrl       String?
  
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  createdAt     DateTime @default(now())
}

model AuditLog {
  id            String   @id @default(cuid())
  userId        String?
  action        String
  details       String?
  ipAddress     String?
  
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  createdAt     DateTime @default(now())
}

model Setting {
  id            String   @id @default(cuid())
  companyId     String   @unique
  theme         String   @default("system")
  emailAlerts   Boolean  @default(true)
  
  company       Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
}

model Analytics {
  id            String   @id @default(cuid())
  date          DateTime
  totalTenders  Int      @default(0)
  tendersWon    Int      @default(0)
  tendersLost   Int      @default(0)
  totalRevenue  Float    @default(0)
  
  createdAt     DateTime @default(now())
}
